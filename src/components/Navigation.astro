---
import ResponsiveToggle from './ResponsiveToggle.astro'
import Logo from './Logo.astro'
import { DarkMode } from 'accessible-astro-components'
import { SUPPORTED_LOCALES } from 'src/i18n/i18n'

/**
 * Navigation Component
 *
 * Renders dual nav elements (desktop + mobile) with shared menu items
 * via <slot />. The mobile menu is hidden by default and toggled by
 * ResponsiveToggle. Breakpoint switches at 900px (nav breakpoint).
 *
 * Accessibility:
 * - Two <nav> landmarks distinguished by aria-label
 * - aria-current="page" set on the active menu item
 * - Full keyboard navigation: Arrow keys, Escape, Tab for dropdowns
 * - Dropdown menus managed with aria-expanded and aria-haspopup
 *
 * @see WCAG 2.1.1 — Keyboard
 * @see WCAG 2.4.5 — Multiple Ways
 * @see WCAG 4.1.2 — Name, Role, Value
 */
---

<div id="main-navigation" class="py-8" data-locales={JSON.stringify(SUPPORTED_LOCALES)}>
  <div class="container">
    <div class="nav-bar">
      <Logo />
      <div class="wrapper">
        <nav class="desktop-menu" aria-label="Main navigation">
          <ul class="menu">
            <slot />
          </ul>
        </nav>
        <DarkMode />
        <ResponsiveToggle />
      </div>
    </div>
    <nav class="mobile-menu" aria-label="Mobile navigation">
      <ul class="menu">
        <slot />
      </ul>
    </nav>
  </div>
</div>

<script>
  import { initializeNavigation } from '../utils/navigation'

  document.addEventListener('astro:page-load', initializeNavigation)
  initializeNavigation()
</script>
