---
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import { getLocalizedPageLoader } from '../i18n/localizedPages'

interface Props {
  route: string
}

const { route } = Astro.props
const loadPage = getLocalizedPageLoader(route)

if (!loadPage) {
  throw new Error(`Missing localized source page for route "${route || '/'}".`)
}

const mod = (await loadPage()) as { default: any }
const Component = mod.default
---

<Component />
