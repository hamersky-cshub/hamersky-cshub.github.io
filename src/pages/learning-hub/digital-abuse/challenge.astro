---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'

const pairs = [
  { id: 1, keyword: "Digital Abuse",    definition: "Using technology to hurt, threaten, or control someone online." },
  { id: 2, keyword: "Cyberbullying",    definition: "Repeated harmful online behaviour that targets a specific person." },
  { id: 3, keyword: "Harassment",       definition: "Unwanted messages or actions meant to upset or frighten someone." },
  { id: 4, keyword: "Blocking",         definition: "A platform feature that stops someone from contacting you." },
  { id: 5, keyword: "Reporting",        definition: "Telling a platform or trusted adult about harmful online behaviour." },
  { id: 6, keyword: "Screenshot",       definition: "A saved image of your screen, useful for keeping evidence of abuse." },
  { id: 7, keyword: "Trusted Adult",    definition: "A parent, teacher, or guardian who can help you stay safe." },
  { id: 8, keyword: "Online Boundary",  definition: "A personal rule about what you are comfortable sharing or doing online." },
  { id: 9, keyword: "Threat",           definition: "A message designed to make someone feel scared or in danger." },
  { id: 10, keyword: "Grooming",        definition: "Gradually building trust with someone in order to manipulate them." },
]
---

<DefaultLayout title="Safety Dictionary">
  <PageHeader
    title="Safety Dictionary"
    subtitle="Pair each keyword with its definition. Learn the language of safety and what to do when something feels wrong online."
    bgType="bordered"
  />

  <section class="my-12">
    <div class="container mb-12">
      <div class="mb-10 flex flex-col gap-6">
        <h2 class="mb-2">How It Works</h2>
        <p>
          Click a keyword, then click the definition that matches it. Get all 10 pairs to win.
        </p>
        <div class="tip-card">
          Tip: If a message makes you feel scared, rushed, or confused, pause and talk to a trusted adult.
        </div>
      </div>
    </div>
  </section>

  <section class="match-game" data-match-game>
    <div class="container">

      <div class="match-game__toolbar">
        <div class="match-game__score" data-score aria-live="polite">Score: 0 / {pairs.length}</div>
        <button class="button match-game__restart" type="button" data-restart>Restart</button>
      </div>

      <div class="match-game__attempt-msg" data-attempt-msg aria-live="polite"></div>

      <div class="match-game__board">
        <div class="match-game__col" data-keywords>
          {pairs.map((p) => (
            <button
              class="match-tile match-tile--keyword"
              type="button"
              data-id={p.id}
              data-type="keyword"
            >
              {p.keyword}
            </button>
          ))}
        </div>

        <div class="match-game__col" data-definitions>
          {pairs.map((p) => (
            <button
              class="match-tile match-tile--definition"
              type="button"
              data-id={p.id}
              data-type="definition"
            >
              {p.definition}
            </button>
          ))}
        </div>
      </div>

      <div class="match-game__win" data-win hidden>
        <div class="match-game__win-inner">
          <span class="match-game__win-icon">🎉</span>
          <h2>You matched them all!</h2>
          <p>Great work — you know the language of online safety.</p>
          <button class="button" type="button" data-restart>Play Again</button>
        </div>
      </div>

    </div>
  </section>
</DefaultLayout>

<script>
  document.querySelectorAll('[data-match-game]').forEach((root) => {
    const keywordCol   = root.querySelector('[data-keywords]')
    const defCol       = root.querySelector('[data-definitions]')
    const scoreEl      = root.querySelector('[data-score]')
    const attemptMsg   = root.querySelector('[data-attempt-msg]')
    const winPanel     = root.querySelector('[data-win]')
    const restartBtns  = root.querySelectorAll('[data-restart]')

    const totalPairs   = root.querySelectorAll('[data-type="keyword"]').length
    let score          = 0
    let selectedTile: HTMLButtonElement | null = null
    let busy           = false

    // ── Shuffle helper ────────────────────────────────────────────────────────
    const shuffle = (col: Element) => {
      const tiles = Array.from(col.querySelectorAll('.match-tile'))
      for (let i = tiles.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1))
        col.appendChild(tiles[j])
        tiles.splice(j, 1)
      }
    }

    // ── Update score display ──────────────────────────────────────────────────
    const updateScore = () => {
      scoreEl!.textContent = `Score: ${score} / ${totalPairs}`
    }

    // ── Clear attempt message ─────────────────────────────────────────────────
    let clearMsgTimer: ReturnType<typeof setTimeout>
    const showMsg = (text: string, type: 'correct' | 'wrong') => {
      clearTimeout(clearMsgTimer)
      attemptMsg!.textContent = text
      attemptMsg!.className = `match-game__attempt-msg match-game__attempt-msg--${type}`
      clearMsgTimer = setTimeout(() => {
        attemptMsg!.textContent = ''
        attemptMsg!.className = 'match-game__attempt-msg'
      }, 1800)
    }

    // ── Deselect all tiles ────────────────────────────────────────────────────
    const deselectAll = () => {
      root.querySelectorAll('.match-tile--selected').forEach((t) =>
        t.classList.remove('match-tile--selected')
      )
      selectedTile = null
    }

    // ── Handle a tile click ───────────────────────────────────────────────────
    const handleClick = (tile: HTMLButtonElement) => {
      if (busy) return
      if (tile.disabled) return

      const type = tile.dataset.type!
      const id   = tile.dataset.id!

      // Clicking the already-selected tile → deselect
      if (tile.classList.contains('match-tile--selected')) {
        tile.classList.remove('match-tile--selected')
        selectedTile = null
        return
      }

      // No tile selected yet → select this one
      if (!selectedTile) {
        tile.classList.add('match-tile--selected')
        selectedTile = tile
        return
      }

      // A tile of the same type → swap selection
      if (selectedTile.dataset.type === type) {
        deselectAll()
        tile.classList.add('match-tile--selected')
        selectedTile = tile
        return
      }

      // Two tiles of different types selected → evaluate
      const firstTile  = selectedTile
      const secondTile = tile

      busy = true
      secondTile.classList.add('match-tile--selected')

      if (firstTile.dataset.id === secondTile.dataset.id) {
        // ✅ Correct match
        firstTile.classList.remove('match-tile--selected')
        secondTile.classList.remove('match-tile--selected')
        firstTile.classList.add('match-tile--matched')
        secondTile.classList.add('match-tile--matched')

        setTimeout(() => {
          firstTile.classList.add('match-tile--gone')
          secondTile.classList.add('match-tile--gone')
          firstTile.disabled  = true
          secondTile.disabled = true
          score++
          updateScore()
          showMsg('✓ Correct match!', 'correct')

          if (score === totalPairs) {
            setTimeout(() => { winPanel!.hidden = false }, 400)
          }
          selectedTile = null
          busy = false
        }, 500)
      } else {
        // ❌ Wrong match
        firstTile.classList.add('match-tile--wrong')
        secondTile.classList.add('match-tile--wrong')

        showMsg('✗ Not a match — try again.', 'wrong')

        setTimeout(() => {
          firstTile.classList.remove('match-tile--selected', 'match-tile--wrong')
          secondTile.classList.remove('match-tile--selected', 'match-tile--wrong')
          selectedTile = null
          busy = false
        }, 700)
      }
    }

    // ── Attach listeners ──────────────────────────────────────────────────────
    root.querySelectorAll<HTMLButtonElement>('.match-tile').forEach((tile) => {
      tile.addEventListener('click', () => handleClick(tile))
    })

    // ── Restart ───────────────────────────────────────────────────────────────
    const restart = () => {
      score        = 0
      selectedTile = null
      busy         = false
      winPanel!.hidden = true
      attemptMsg!.textContent = ''
      attemptMsg!.className   = 'match-game__attempt-msg'

      root.querySelectorAll<HTMLButtonElement>('.match-tile').forEach((tile) => {
        tile.className = tile.dataset.type === 'keyword'
          ? 'match-tile match-tile--keyword'
          : 'match-tile match-tile--definition'
        tile.disabled = false
      })

      shuffle(keywordCol!)
      shuffle(defCol!)
      updateScore()
    }

    restartBtns.forEach((btn) => btn.addEventListener('click', restart))

    // ── Initial shuffle ───────────────────────────────────────────────────────
    shuffle(keywordCol!)
    shuffle(defCol!)
    updateScore()
  })
</script>

<style>
  /* ── Tip card ────────────────────────────────────────────────────────────── */
  .tip-card {
    border-radius: 0.9rem;
    border: 1px solid #bae6fd;
    background: linear-gradient(135deg, #e0f2fe, #f0f9ff);
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    color: #075985;
  }

  /* ── Game wrapper ────────────────────────────────────────────────────────── */
  .match-game {
    margin-bottom: var(--space-3xl);
  }

  /* ── Toolbar ─────────────────────────────────────────────────────────────── */
  .match-game__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    margin-bottom: var(--space-m);
    flex-wrap: wrap;
  }

  .match-game__score {
    font-size: var(--font-size-2);
    font-weight: 700;
    padding: var(--space-2xs) var(--space-s);
    border: 2px solid var(--border-color-subtle);
    border-radius: var(--radius-s);
  }

  .match-game__restart {
    border-color: var(--link-color);
    background-color: var(--background-color);
    color: var(--link-color);
  }

  .match-game__restart:where(:hover, :focus-visible) {
    background-color: var(--link-color);
    color: var(--background-color);
  }

  /* ── Attempt message ─────────────────────────────────────────────────────── */
  .match-game__attempt-msg {
    min-height: 1.8rem;
    font-weight: 600;
    font-size: var(--font-size-0);
    margin-bottom: var(--space-s);
    transition: color 0.2s;
  }

  .match-game__attempt-msg--correct { color: #15803d; }
  .match-game__attempt-msg--wrong   { color: #b91c1c; }

  /* ── Board ───────────────────────────────────────────────────────────────── */
  .match-game__board {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m);
    align-items: start;
  }

  @media (max-width: 640px) {
    .match-game__board {
      grid-template-columns: 1fr;
    }
  }

  .match-game__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  /* ── Tiles ───────────────────────────────────────────────────────────────── */
  .match-tile {
    width: 100%;
    text-align: left;
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-m);
    border: 2px solid var(--border-color-subtle);
    background: var(--background-color);
    font-size: var(--font-size-0);
    line-height: 1.45;
    cursor: pointer;
    transition:
      border-color 0.18s,
      background-color 0.18s,
      color 0.18s,
      opacity 0.3s,
      transform 0.18s,
      box-shadow 0.18s;
    box-shadow: var(--elevation-1);
  }

  .match-tile--keyword {
    font-weight: 700;
    font-size: var(--font-size-1);
    border-left: 4px solid var(--brand-DA);
  }

  .match-tile--definition {
    color: var(--color-neutral-700);
    border-left: 4px solid var(--border-color-subtle);
  }

  /* Hover */
  .match-tile:where(:hover, :focus-visible):not(:disabled):not(.match-tile--matched):not(.match-tile--gone) {
    border-color: var(--brand-DA);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand-DA), transparent 80%);
    transform: translateY(-1px);
  }

  /* Selected */
  .match-tile--selected {
    background-color: color-mix(in oklab, var(--brand-DA), white 75%);
    border-color: var(--brand-DA);
    color: color-mix(in oklab, var(--brand-DA), black 30%);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand-DA), transparent 60%);
  }

  .match-tile--keyword.match-tile--selected {
    border-left-color: var(--brand-DA);
  }

  .match-tile--definition.match-tile--selected {
    border-left-color: var(--brand-DA);
    color: color-mix(in oklab, var(--brand-DA), black 30%);
  }

  /* Wrong flash */
  .match-tile--wrong {
    background-color: #fee2e2;
    border-color: #ef4444;
    color: #991b1b;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.3);
    animation: shake 0.35s ease;
  }

  @keyframes shake {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(-5px); }
    40%  { transform: translateX(5px); }
    60%  { transform: translateX(-4px); }
    80%  { transform: translateX(4px); }
    100% { transform: translateX(0); }
  }

  /* Matched — brief green glow before disappearing */
  .match-tile--matched {
    background-color: #dcfce7;
    border-color: #16a34a;
    color: #14532d;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.3);
  }

  /* Gone */
  .match-tile--gone {
    opacity: 0;
    pointer-events: none;
    height: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    margin: 0 !important;
    border: none !important;
    box-shadow: none !important;
    overflow: hidden;
    transition:
      opacity 0.4s,
      height 0.4s 0.1s,
      padding 0.4s 0.1s,
      margin 0.4s 0.1s;
  }

  /* Disabled (matched) */
  .match-tile:disabled {
    cursor: default;
  }

  /* ── Win panel ───────────────────────────────────────────────────────────── */
  .match-game__win {
    margin-top: var(--space-xl);
  }

  .match-game__win-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
    padding: var(--space-xl);
    border-radius: var(--radius-l);
    border: 3px solid #16a34a;
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    box-shadow: var(--elevation-2);
    text-align: center;
  }

  .match-game__win-icon {
    font-size: 3rem;
    line-height: 1;
  }

  .match-game__win-inner h2 {
    color: #14532d;
  }

  .match-game__win-inner p {
    color: #166534;
    max-width: 40ch;
  }
</style>
