---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Icon } from 'astro-icon/components'
import { localizePath } from 'src/i18n/i18n'
import { getModule } from 'src/data/modules'
import type { ModuleId } from 'src/data/modules'
import { modulePartsData, mergeParts } from 'src/data/moduleParts'
import type { TranslationPart, TeachersGuide, RelatedModuleCard, MergedPart, MergedMaterial, MergedActivityStep } from 'src/data/moduleParts'
import { useTranslations } from 'src/i18n/index'

const locale = Astro.currentLocale
const { t, v } = useTranslations(locale)

const objectives = v<ReadonlyArray<string>>('contentAP.objectives') ?? []
const outcomes = v<ReadonlyArray<string>>('contentAP.outcomes') ?? []
const teachersGuide = v<TeachersGuide>('contentAP.teachersGuide') ?? {}
const currentModule = getModule('ap')!
const parts = mergeParts('ap', v<ReadonlyArray<TranslationPart>>('contentAP.parts') ?? [])
const relatedModuleCards = (v<ReadonlyArray<RelatedModuleCard>>('contentAP.relatedModuleCards') ?? []).map(card => { const mod = getModule(card.moduleId); if (!mod) return card; return { ...card, parts: modulePartsData[mod.id].length, materials: mod.materials, videos: mod.videos, challenges: mod.challenges, games: mod.games } })

const hasCount = (value: unknown): value is number => typeof value === 'number' && value > 0

const formatCount = (count: number, singularKey: string, pluralKey: string) =>
  `${count} ${t(count === 1 ? singularKey : pluralKey)}`

const getPartTitle = (part: MergedPart) => (part.titleKey ? t(part.titleKey) : String(part.title ?? ''))

const moduleImages = {
  dc: '/images/learning-hub/01_digital-citizenship.png',
  ap: '/images/learning-hub/02_attacker-perspective.png',
  at: '/images/learning-hub/03_authentication.png',
  dp: '/images/learning-hub/04_data-privacy.png',
  se: '/images/learning-hub/05_social-engineering.png',
  mw: '/images/learning-hub/06_malware.png',
  da: '/images/learning-hub/07_digital-abuse.png',
}
---

<DefaultLayout title={t('modules.ap.title')}>
  <PageHeader
    title={t('modules.ap.title')}
    subtitle={t('contentAP.subtitle')}
    underlineColor="var(--brand-AP)"
    bgType="module"
    buttons={[
      { 
        text: t('contentPage.downloadGuide'), 
        href: currentModule.teachersGuide.href,
        variant: "primary",
        icon: "lucide:download",
        download: teachersGuide.download ?? '',
      },
      { 
        text: t('contentPage.downloadAll'), 
        href: '/materials/attacker-perspective/attacker-perspective.zip', 
        variant: 'primary', 
        icon: 'lucide:download', 
        download: 'Attacker Perspective Material Package' 
      },
    ]}
  />

  <!-- Main Content Area -->
  <section class="my-12">
    <div class="container">

      <!-- Learning Overview: Aim / Objectives / Outcomes tabs -->
      <div class="aoo-card">
        <div class="ap-tabs">
          <div class="ap-tabs__bar" role="tablist">
            <button class="ap-tab" role="tab" aria-selected="true" data-panel="aoo-aim">
              <img class="ap-tab-img-icon" src="/images/learning-hub/aim.png" alt="" aria-hidden="true" />
              {t('contentPage.aimTitle')}
            </button>
            <button class="ap-tab" role="tab" aria-selected="false" data-panel="aoo-objectives">
              <img class="ap-tab-img-icon" src="/images/learning-hub/objectives.png" alt="" aria-hidden="true" />
              {t('contentPage.objectivesTitle')}
              <span class="ap-tab__badge">{objectives.length}</span>
            </button>
            <button class="ap-tab" role="tab" aria-selected="false" data-panel="aoo-outcomes">
              <img class="ap-tab-img-icon" src="/images/learning-hub/outcomes.png" alt="" aria-hidden="true" />
              {t('contentPage.outcomesTitle')}
              <span class="ap-tab__badge">{outcomes.length}</span>
            </button>
          </div>

          <div class="ap-tab-panel" role="tabpanel" id="aoo-aim">
            <div class="ap-aim-content">
              <p class="ap-aim-text">{t('contentAP.aim')}</p>
            </div>
          </div>

          <div class="ap-tab-panel" role="tabpanel" id="aoo-objectives" hidden>
            <ul class="ap-step-list">
              {objectives.map((obj, i) => (
                <li class="ap-step-item ap-step-item--plain">
                  <span class="ap-step-num">{String(i + 1).padStart(2, '0')}</span>
                  <p class="ap-step-title">{obj}</p>
                </li>
              ))}
            </ul>
          </div>

          <div class="ap-tab-panel" role="tabpanel" id="aoo-outcomes" hidden>
            <ul class="ap-step-list">
              {outcomes.map((outcome, i) => (
                <li class="ap-step-item ap-step-item--plain">
                  <span class="ap-step-num">{String(i + 1).padStart(2, '0')}</span>
                  <p class="ap-step-title">{outcome}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Section Divider: Module Content -->
      <div class="ap-divider ap-divider--center" style="margin-top: var(--space-xl);" id="module-content"><b>{t('contentPage.moduleContent')}</b></div>

      <!-- Module Parts List -->
      <div class="ap-section">
        <div class="ap-module-list">
          <div class="ap-module-row">
            <a class="ap-part-button" href="#teachers-guide">{t('contentPage.guideLabel')}</a>
            <div class="ap-teaching-guide" id="teachers-guide">
              <div class="ap-package-banner__copy">
                <h3>{t('contentPage.teachersGuideTitle')}</h3>
                <p class="ap-package-banner__sub">{t('contentPage.guideDescription')}</p>
              </div>
              <div class="ap-package-btn-wrap">
                <a
                  class="button has-icon ap-package-btn"
                  href={currentModule.teachersGuide.href}
                  download={teachersGuide.download ?? ''}
                  aria-label={String(teachersGuide.ariaLabel ?? '')}
                >
                  <Icon name="lucide:download" />
                  {t('contentPage.teachersGuideDownload')}
                </a>
              </div>
            </div>
          </div>

          {parts.map((part) => {
            const meta = part.meta ?? {}
            const included = part.included ?? {}
            const partMaterials = included.materials ?? []
            const partActivity = included.activityPlan ?? []
            const featuredVideo = part.featuredVideo
            const title = getPartTitle(part)
            const firstPanel = partActivity.length ? 'activity' : partMaterials.length ? 'materials' : 'video'

            return (
              <div class="ap-module-row">
                <a class="ap-part-button" href={`#${String(part.anchorId ?? '')}`}>{t('hub.partLabel')} {String(part.number ?? '')}</a>
                <details class="ap-module" id={String(part.anchorId ?? '')}>
                  <summary class="ap-module__header">
                    <div class="ap-module__copy">
                      <h3>{title}</h3>
                      <div class="ap-module__meta">
                        {hasCount(meta.steps) ? (
                          <span class="ap-meta-item"><Icon name="lucide:list-checks" /> {formatCount(meta.steps, 'contentPage.stepSingular', 'contentPage.stepPlural')}</span>
                        ) : null}
                        {hasCount(meta.materials) ? (
                          <span class="ap-meta-item"><Icon name="lucide:file-text" /> {formatCount(meta.materials, 'contentPage.materialSingular', 'contentPage.materialPlural')}</span>
                        ) : null}
                        {hasCount(meta.videos) ? (
                          <span class="ap-meta-item"><Icon name="lucide:play-circle" /> {formatCount(meta.videos, 'contentPage.videoSingular', 'contentPage.videoPlural')}</span>
                        ) : null}
                      </div>
                      <p class="ap-goal"><b>{t('contentPage.goalLabel')}</b> {String(part.goal ?? '')}</p>
                    </div>
                    <span class="ap-module__toggle" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M8 5l8 7-8 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="ap-module__content">
                    <div class="ap-package-banner">
                      <div class="ap-package-banner__copy">
                        <p class="ap-package-banner__title">{t('contentPage.materialPackage')}</p>
                        <p class="ap-package-banner__sub">{t('contentPage.materialPackageSub')}</p>
                      </div>
                      <div class="ap-package-btn-wrap">
                        <a
                          class="button has-icon ap-package-btn"
                          href={String(part.bundle?.href ?? '')}
                          download={String(part.bundle?.filename ?? '')}
                        >
                          <Icon name="lucide:download" />
                          {t('contentPage.downloadPart')}
                        </a>
                      </div>
                    </div>

                    {(partMaterials.length || partActivity.length || featuredVideo) ? (
                      <div class="ap-tabs">
                        <div class="ap-tabs__bar" role="tablist">
                          {partActivity.length ? (
                            <button
                              class="ap-tab"
                              role="tab"
                              aria-selected={firstPanel === 'activity' ? 'true' : 'false'}
                              data-panel={`activity-${part.anchorId}`}
                            >
                              <Icon name="lucide:list" />
                              {t('contentPage.activityPlan')}
                              <span class="ap-tab__badge">{partActivity.length}</span>
                            </button>
                          ) : null}
                          {partMaterials.length ? (
                            <button
                              class="ap-tab"
                              role="tab"
                              aria-selected={firstPanel === 'materials' ? 'true' : 'false'}
                              data-panel={`materials-${part.anchorId}`}
                            >
                              <Icon name="lucide:file-text" />
                              {t('contentPage.materialPlural')}
                              <span class="ap-tab__badge">{partMaterials.length}</span>
                            </button>
                          ) : null}
                          {featuredVideo ? (
                            <button
                              class="ap-tab"
                              role="tab"
                              aria-selected={firstPanel === 'video' ? 'true' : 'false'}
                              data-panel={`video-${part.anchorId}`}
                            >
                              <Icon name="lucide:video" />
                              {t('contentPage.videoSingular')}
                              <span class="ap-tab__badge">1</span>
                            </button>
                          ) : null}
                        </div>

                        {partMaterials.length ? (
                          <div
                            class="ap-tab-panel"
                            role="tabpanel"
                            id={`materials-${part.anchorId}`}
                            hidden={firstPanel !== 'materials'}
                          >
                            <ul class="ap-step-list">
                              {partMaterials.map((item: MergedMaterial, i: number) => (
                                <li class="ap-step-item">
                                  <span class="ap-step-num">{String(i + 1).padStart(2, '0')}</span>
                                  <p class="ap-step-title"><b>{String(item.kind ?? '')}:</b> {String(item.name ?? '')}</p>
                                  <a
                                    class="ap-item-download"
                                    href={String(item.href ?? '')}
                                    download={String(item.filename ?? '')}
                                    aria-label={String(item.ariaLabel ?? '')}
                                  >
                                    <Icon name="lucide:download" />
                                    <span>{t('contentPage.download')}</span>
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ) : null}

                        {partActivity.length ? (
                          <div
                            class="ap-tab-panel"
                            role="tabpanel"
                            id={`activity-${part.anchorId}`}
                            hidden={firstPanel !== 'activity'}
                          >
                            <ul class="ap-step-list">
                              {partActivity.map((step: MergedActivityStep) => (
                                <li class="ap-step-item ap-step-item--plain">
                                  <span class="ap-step-num">{String(step.stepNumber ?? 0).padStart(2, '0')}</span>
                                  <p class="ap-step-title"><b>{t('contentPage.stepSingular')} {String(step.stepNumber ?? '')}:</b> {String(step.title ?? '')}</p>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ) : null}

                        {featuredVideo ? (
                          <div
                            class="ap-tab-panel"
                            role="tabpanel"
                            id={`video-${part.anchorId}`}
                            hidden={firstPanel !== 'video'}
                          >
                            <div class="ap-video-preview">
                              <div class="ap-video-preview__thumb">
                                <video
                                  controls
                                  preload="metadata"
                                  poster={String(featuredVideo.posterSrc ?? '')}
                                >
                                  <source src={String(featuredVideo.videoSrc ?? '')} />
                                  {(featuredVideo.tracks ?? []).map((track) => (
                                    <track
                                      label={String(track.label ?? '')}
                                      kind="subtitles"
                                      srclang={String(track.srclang ?? '')}
                                      src={String(track.src ?? '')}
                                    />
                                  ))}
                                </video>
                              </div>
                              <div class="ap-video-preview__info">
                                <h4 class="ap-video-preview__title">{String(featuredVideo.title ?? '')}</h4>
                                <p class="ap-video-preview__desc">{String(featuredVideo.supportText ?? '')}</p>
                                <div class="ap-video-preview__actions">
                                  <div class="ap-video-action-wrap">
                                    <a
                                      class="ap-item-download"
                                      href={String(featuredVideo.downloads?.video?.href ?? '')}
                                      download={String(featuredVideo.downloads?.video?.filename ?? '')}
                                      aria-label={String(featuredVideo.downloads?.video?.ariaLabel ?? '')}
                                    >
                                      <Icon name="lucide:download" />
                                      <span>{t('contentPage.videoSingular')}</span>
                                    </a>
                                  </div>
                                  <div class="ap-video-action-wrap">
                                    <a
                                      class="ap-item-download"
                                      href={String(featuredVideo.downloads?.subtitles?.href ?? '')}
                                      download={String(featuredVideo.downloads?.subtitles?.filename ?? '')}
                                      aria-label={String(featuredVideo.downloads?.subtitles?.ariaLabel ?? '')}
                                    >
                                      <Icon name="lucide:captions" />
                                      <span>{t('contentPage.subtitlesSingular')}</span>
                                    </a>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        ) : null}
                      </div>
                    ) : null}
                  </div>
                </details>
              </div>
            )
          })}
        </div>
      </div>

      <!-- Section Divider: Related Modules -->
      <div class="ap-divider ap-divider--center"><b>{t('contentPage.relatedModules')}</b></div>

      <!-- Related Modules -->
      <div class="ap-section">
        <div class="ap-section__header">
          <h2>{t('contentPage.relatedModules')}</h2>
          <p class="ap-section__subtitle">{t('contentPage.relatedModulesSubtitle')}</p>
        </div>

        <div class="ap-rm-list">
          {relatedModuleCards.map((card, idx) => {
            const moduleId = String(card.moduleId ?? '')
            const title = t(`modules.${moduleId}.title`)
            const href = localizePath(locale, String(card.href ?? ''))
            const image = moduleImages[moduleId as keyof typeof moduleImages]
            const brandVar = `var(--brand-${String(card.brand ?? '')})`

            return (
              <a
                class={`ap-rm-row${idx === 0 ? ' ap-rm-row--first' : ''}`}
                href={href}
                style={`--rm-color: ${brandVar};`}
              >
                <div class="ap-rm-icon">
                  <img src={image} alt="" decoding="async" loading="eager" />
                </div>
                <div class="ap-rm-body">
                  <strong class="ap-rm-title">{title}</strong>
                  <span class="ap-rm-desc">{String(card.description ?? '')}</span>
                </div>
                <div class="ap-rm-meta" aria-label={title}>
                  {hasCount(card.parts) ? (
                    <span class="ap-rm-stat">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                      {card.parts}
                    </span>
                  ) : null}
                  {hasCount(card.materials) ? (
                    <span class="ap-rm-stat">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>
                      {card.materials}
                    </span>
                  ) : null}
                  {hasCount(card.videos) ? (
                    <span class="ap-rm-stat">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                      {card.videos}
                    </span>
                  ) : null}
                  {hasCount(card.challenges) ? (
                    <span class="ap-rm-stat">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                      {card.challenges}
                    </span>
                  ) : null}
                  {hasCount(card.games) ? (
                    <span class="ap-rm-stat">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 12h4M8 10v4"/><circle cx="15" cy="11" r="0.8" fill="currentColor" stroke="none"/><circle cx="17" cy="13" r="0.8" fill="currentColor" stroke="none"/><path d="M2 9a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v1c0 1-0.5 2-1 2.5L19 17a3 3 0 0 1-2.5 1.5h-9A3 3 0 0 1 5 17l-2-4.5C2.5 12 2 11 2 10V9z"/></svg>
                      {card.games}
                    </span>
                  ) : null}
                </div>
                <span class="ap-rm-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 5l8 7-8 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            )
          })}
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<script>
  const expandFromHash = () => {
    const hash = window.location.hash.slice(1)
    if (!hash) return

    const target = document.getElementById(hash)
    if (target instanceof HTMLDetailsElement) {
      target.open = true
      requestAnimationFrame(() => {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' })
      })
    }
  }

  document.addEventListener('astro:page-load', expandFromHash)
  expandFromHash()

  const initTabs = () => {
    document.querySelectorAll('.ap-tabs').forEach(tabs => {
      const bar = tabs.querySelector('.ap-tabs__bar')
      if (!bar) return
      bar.addEventListener('click', e => {
        const btn = (e.target as Element).closest('[role="tab"]') as HTMLElement | null
        if (!btn) return
        const targetId = btn.dataset.panel
        if (!targetId) return
        bar.querySelectorAll('[role="tab"]').forEach(t => {
          t.setAttribute('aria-selected', t === btn ? 'true' : 'false')
        })
        tabs.querySelectorAll('[role="tabpanel"]').forEach(p => {
          (p as HTMLElement).hidden = p.id !== targetId
        })
      })
    })
  }

  document.addEventListener('astro:page-load', initTabs)
  initTabs()
</script>

<style>
  .ap-grid {
    display: grid;
    gap: var(--space-l);
  }

  .ap-grid--two {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .ap-grid--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .ap-grid--four {
    grid-template-columns: 1fr;
    gap: var(--space-m);
  }

  :global(.ap-panel) {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    border: 2px solid #dbe2ea;
    border-radius: var(--radius-l);
    padding: var(--space-l);
    box-shadow: var(--elevation-1);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .ap-panel:hover,
  .ap-panel:focus-within {
    transform: translateY(-4px);
    box-shadow: var(--elevation-3);
    border: 2px solid color-mix(in oklab,var(--brand-AP),white 60%);
  }

  .ap-grid--learning-overview {
    align-items: stretch;
  }

  .ap-panel--compact {
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
  }

  .ap-panel--learning {
    height: 100%;
  }

  .ap-panel--objectives {
    background: linear-gradient(165deg, color-mix(in oklab, var(--color-neutral-100), white 42%), color-mix(in oklab, var(--color-neutral-300), white 28%));
  }

  .ap-panel--outcomes {
    background: linear-gradient(165deg, color-mix(in oklab, var(--color-neutral-100), white 40%), color-mix(in oklab, var(--color-neutral-300), white 26%));
  }

  .ap-panel--learning h3 {
    margin: 0;
    min-height: 2.6rem;
    display: flex;
    align-items: flex-start;
    font-size: clamp(1.35rem, 1vw + 1rem, 1.9rem);
    line-height: 1.1;
  }

  .ap-panel__content {
    margin-top: var(--space-xs);
    border-top: 2px solid color-mix(in oklab, var(--color-neutral-500), white 35%);
    padding-top: var(--space-s);
  }

  .ap-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0;
  }

  .ap-list li {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
    font-size: var(--font-size--1);
    line-height: 1.5;
  }

  .ap-list li + li {
    margin-top: var(--space-s);
    padding-top: var(--space-s);
    border-top: 1px solid color-mix(in oklab, var(--color-neutral-500), white 55%);
  }

  .ap-aim-text {
    margin: 0;
    line-height: 1.32;
    font-size: var(--text-xl);
    color: var(--foreground-color);
  }

  .ap-section {
    margin-top: var(--space-xl);
  }

  .ap-section__header {
    display: grid;
    gap: var(--space-2xs);
    margin-bottom: var(--space-l);
  }

  .ap-section__subtitle {
    color: var(--foreground-color);
  }

  .ap-module-list {
    --ap-part-column: clamp(88px, 11vw, 120px);
    --ap-part-gap: var(--space-l);
    --ap-part-button-height: 2.8rem;
    display: grid;
    gap: var(--ap-part-gap);
  }

  .ap-module-row {
    position: relative;
    display: grid;
    grid-template-columns: var(--ap-part-column) minmax(0, 1fr);
    gap: var(--space-m);
    align-items: start;
  }

  .ap-module-row:not(:last-child)::after {
    content: '';
    position: absolute;
    left: calc(var(--ap-part-column) / 2);
    top: calc(var(--ap-part-button-height) + var(--space-2xs));
    height: calc(100% + var(--ap-part-gap) - var(--ap-part-button-height) - var(--space-s));
    border-left: 2px dashed color-mix(in oklab, var(--brand-AP), white 50%);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .ap-part-button {
    min-height: var(--ap-part-button-height);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0 var(--space-s);
    border: 2px solid var(--brand-AP);
    border-radius: 0.5rem;
    background: var(--brand-AP);
    color: #fff;
    box-shadow: var(--elevation-1);
    text-decoration: none;
    font-size: var(--font-size--3);
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
    position: relative;
    z-index: 1;
    transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .ap-part-button:hover {
    background: transparent;
    color: var(--foreground-color);
    transform: translateY(-1px);
  }

  .ap-part-button:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--brand-AP), black 20%);
    outline-offset: 2px;
  }

  :global(.ap-module) {
    border: 2px solid color-mix(in oklab, var(--brand-AP), white 60%);
    border-radius: 1.25rem;
    padding: 0;
    background: linear-gradient(155deg, color-mix(in oklab, var(--brand-AP), white 92%), #ffffff 55%);
    box-shadow: var(--elevation-2);
    margin-bottom: 0;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ap-module:hover {
    transform: translateY(-3px);
    box-shadow: var(--elevation-3);
  }

  .ap-module__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-m);
    align-items: center;
    list-style: none;
    cursor: pointer;
    padding: clamp(1rem, 2vw, 1.75rem);
  }

  .ap-module__header::-webkit-details-marker {
    display: none;
  }

  .ap-module__header::marker {
    content: '';
  }

  .ap-module__header h3 {
    margin: 0;
    font-size: clamp(1.6rem, 1.3rem + 1vw, 2.4rem);
    line-height: 1.1;
    font-weight: 900;
    text-decoration: underline;
    text-decoration-color: var(--brand-AP);
    text-underline-offset: 0.35rem;
    text-decoration-thickness: 0.15rem;
  }

  .ap-module__header h3 a {
    color: var(--color-neutral-900);
    text-decoration: none;
  }

  .ap-module__header h3 a:hover,
  .ap-module__header h3 a:focus-visible {
    color: var(--brand-AP);
  }

  .ap-module__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, var(--brand-AP), white 60%);
    background: color-mix(in oklab, var(--brand-AP), white 86%);
    color: var(--brand-AP);
    pointer-events: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .ap-module__header:hover .ap-module__toggle {
    background: var(--brand-AP);
    border-color: var(--brand-AP);
    color: #ffffff;
  }

  .ap-module__toggle svg {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.3s ease;
  }

  .ap-module:not([open]) .ap-module__toggle svg {
    transform: rotate(0deg);
  }

  .ap-module[open] .ap-module__toggle svg {
    transform: rotate(90deg);
  }

  .ap-module__content {
    padding: 0 clamp(1rem, 2vw, 1.75rem) clamp(1rem, 2vw, 1.75rem);
  }

  .ap-goal {
    font-size: 1.05rem;
    line-height: 1.5;
    margin-top: var(--space-xs);
    color: var(--foreground-color);
    max-width: 70ch;
  }

  .ap-module__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: var(--space-s);
  }

  .ap-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--foreground-color);
  }

  .ap-meta-item [data-icon] {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: var(--brand-AP);
  }

  .ap-teaching-guide {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-m) var(--space-l);
    border-radius: 1.25rem;
    background: color-mix(in oklab, var(--brand-AP), white 88%);
    border: 1.5px solid color-mix(in oklab, var(--brand-AP), white 60%);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ap-teaching-guide:hover {
    transform: translateY(-3px);
    box-shadow: var(--elevation-3);
  }

  .ap-teaching-guide h3 {
    margin: 0;
    font-size: clamp(1.6rem, 1.3rem + 1vw, 2.4rem);
    line-height: 1.1;
    font-weight: 900;
    text-decoration: underline;
    text-decoration-color: var(--brand-AP);
    text-underline-offset: 0.35rem;
    text-decoration-thickness: 0.15rem;
  }

  /* ── Package Banner ───────────────────────────────────────────────────────── */
  .ap-package-banner {
    margin-top: var(--space-m);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    padding: var(--space-m) var(--space-l);
    border-radius: var(--radius-m);
    background: color-mix(in oklab, var(--brand-AP), white 88%);
    border: 1.5px solid color-mix(in oklab, var(--brand-AP), white 60%);
    overflow: hidden;
  }

  .ap-package-banner__copy {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ap-package-banner__title {
    margin: 0;
    font-weight: 700;
    font-size: var(--font-size-1);
    color: var(--color-neutral-900);
  }

  .ap-package-banner__sub {
    margin-top: var(--space-xs);
    font-size: var(--font-size-0);
    color: var(--foreground-color);
  }

  .ap-package-btn-wrap {
    flex-shrink: 0;
  }

  .ap-package-btn {
    border-radius: 10px;
    background: var(--brand-AP);
    color: #fff;
    border: 2px solid color-mix(in oklab, var(--brand-AP), black 10%);
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .ap-package-btn:hover {
    background: color-mix(in oklab, var(--brand-AP), black 12%);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ── AoO Overview Card ──────────────────────────────────────────────────── */
  .aoo-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid #dbe2ea;
    border-radius: 1rem;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    box-shadow: var(--elevation-1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: var(--space-l);
  }

  .aoo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--elevation-3);
  }

  :global(html.darkmode) .aoo-card {
    background: linear-gradient(180deg, var(--dm-surface-2) 0%, var(--dm-surface-1) 100%);
    border-color: var(--dm-border-sub);
  }

  .aoo-card > .ap-tabs {
    margin-top: 0;
  }

  /* ── Tabs ─────────────────────────────────────────────────────────────────── */
  .ap-tabs {
    margin-top: var(--space-m);
  }

  .ap-tabs__bar {
    display: flex;
    gap: 0;
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    border-bottom: 2px solid color-mix(in oklab, var(--brand-AP), white 70%);
    margin-bottom: var(--space-m);
    padding-right: var(--space-2xs);
  }

  .ap-tabs__bar::-webkit-scrollbar {
    display: none;
  }

  .ap-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: color-mix(in oklab, var(--color-neutral-700), transparent 20%);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .ap-tab:hover {
    color: var(--brand-AP);
  }

  .ap-tab[aria-selected="true"] {
    color: var(--color-neutral-900);
    border-bottom-color: var(--brand-AP);
    font-weight: 700;
  }

  .ap-tab [data-icon] {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .ap-tab__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.4rem;
    height: 1.4rem;
    padding: 0 0.3rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--brand-AP), white 75%);
    color: color-mix(in oklab, var(--brand-AP), black 15%);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
  }

  .ap-tab[aria-selected="true"] .ap-tab__badge {
    background: var(--brand-AP);
    color: #fff;
  }

  /* ── Step List ────────────────────────────────────────────────────────────── */
  .ap-step-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ap-step-item {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr) auto;
    gap: var(--space-s);
    align-items: center;
    padding: var(--space-s) 0;
    border-bottom: 1px dashed color-mix(in oklab, var(--brand-AP), white 65%);
  }

  .ap-step-item:last-child {
    border-bottom: none;
  }

  .ap-step-num {
    font-size: var(--font-size-1);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: color-mix(in oklab, var(--brand-AP), black 15%);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .ap-step-title {
    margin: 0;
    font-size: var(--font-size-0);
    line-height: 1.4;
    color: var(--foreground-color);
  }

  /* ── Video Preview Card ───────────────────────────────────────────────────── */
  .ap-video-preview {
    display: grid;
    grid-template-columns: minmax(140px, 350px) 1fr;
    gap: var(--space-m);
    background: color-mix(in oklab, var(--brand-AP), white 93%);
    border: 1.5px solid color-mix(in oklab, var(--brand-AP), white 72%);
    border-radius: var(--radius-m);
    padding: var(--space-m);
    align-items: center;
    overflow: hidden;
  }

  .ap-video-preview__thumb {
    border-radius: var(--radius-s);
    overflow: hidden;
    background: #111;
    flex-shrink: 0;
  }

  .ap-video-preview__thumb video {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .ap-video-preview__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .ap-video-preview__title {
    margin: 0;
    font-size: var(--font-size-1);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-neutral-900);
  }

  .ap-video-preview__desc {
    margin: 0;
    font-size: var(--font-size-0);
    line-height: 1.5;
    color: var(--foreground-color);
  }

  .ap-video-preview__actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .ap-divider {
    margin: var(--space-l) 0 var(--space-m);
    display: flex;
    align-items: center;
    gap: var(--space-s);
    font-size: var(--font-size--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, var(--brand-AP), black 20%);
  }

  .ap-divider::before,
  .ap-divider::after {
    content: '';
    flex: 1;
    border-top: 1px solid var(--brand-AP);
  }

  .ap-divider--center {
    justify-content: center;
    color: var(--foreground-color);
  }

  .ap-divider--center::before,
  .ap-divider--center::after {
    flex: 0.6;
  }

  .ap-item-download {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid color-mix(in oklab,var(--brand-AP),white 45%);
    color: color-mix(in oklab, var(--brand-AP), black 10%);
    background: #fff;
    text-decoration: none;
    border-radius: 10px;
    padding: 0.35rem 0.8rem;
    font-weight: 700;
    font-size: var(--font-size--1);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .ap-item-download:hover {
    background-color: var(--brand-AP);
    color: #fff;
    border-color: color-mix(in oklab, var(--brand-AP), black 6%);
    transform: translateY(-1px);
  }

  .ap-module-card {
    border: 2px solid color-mix(in oklab, var(--module-card-color, var(--brand-AP)), white 30%);
    border-radius: var(--radius-l);
    padding: var(--space-m);
    background: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), white 90%);
    box-shadow: var(--elevation-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    align-content: start;
  }

  .ap-module-card h4 {
    color: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), black 2%);
  }

  .ap-card-text {
    color: var(--foreground-color);
  }

  .ap-card-button {
    width: 100%;
    justify-content: center;
    border-radius: 10px;
    margin-top: auto;
    background: var(--module-card-color, var(--brand-AP));
    color: #fff;
    border: 2px solid color-mix(in oklab,var(--module-card-color, var(--brand-AP)),white 30%);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .ap-card-button:hover {
    background: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), black 10%);
    color: #fff;
    border: 2px solid color-mix(in oklab, var(--module-card-color, var(--brand-AP)), black 10%);
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .ap-grid--three {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ap-panel--aim {
      grid-column: 1 / -1;
    }

    .ap-module-list {
      --ap-part-column: 96px;
    }
  }

  @media (max-width: 700px) {
    .ap-grid--three {
      grid-template-columns: 1fr;
    }

    .ap-panel--aim {
      grid-column: auto;
    }

    .ap-module-row {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .ap-module-row::after {
      display: none;
    }

    .ap-part-button {
      width: fit-content;
      min-width: 7rem;
      justify-self: start;
    }

    .ap-package-banner {
      flex-direction: column;
      align-items: stretch;
      padding: var(--space-s) var(--space-m);
    }

    .ap-package-banner__title {
      font-size: var(--font-size-0);
    }

    .ap-package-btn-wrap {
      align-self: stretch;
    }

    .ap-package-btn {
      width: auto;
      justify-content: center;
      white-space: normal;
      text-align: center;
      font-size: 0.9rem;
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
    }

    .ap-video-preview__actions {
      flex-direction: column;
    }

    .ap-video-action-wrap {
      width: 100%;
    }

    .ap-video-action-wrap .ap-item-download {
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
      justify-content: center;
    }

    .ap-tab {
      padding: 0.5rem 0.7rem;
      font-size: 0.875rem;
      white-space: nowrap;
      gap: 0.3rem;
    }

    .ap-tab [data-icon] {
      display: none;
    }

    .ap-step-item {
      grid-template-columns: 2rem minmax(0, 1fr) auto;
    }

    .ap-video-preview {
      grid-template-columns: 1fr;
    }

    .ap-video-preview__title {
      font-size: var(--font-size-0);
    }
  }

  @media (max-width: 480px) {
    .ap-tab {
      padding: 0.45rem 0.55rem;
      font-size: 0.70rem;
    }

    .ap-tab__badge {
      min-width: 1.2rem;
      height: 1.2rem;
      font-size: 0.7rem;
    }

    .ap-step-item {
      grid-template-columns: 2rem 1fr;
      row-gap: var(--space-xs);
    }

    .ap-step-item > :last-child {
      grid-column: 2;
      justify-self: start;
    }

    .ap-step-title {
      font-size: 0.9rem;
    }
  }

  /* ── Dark mode overrides ─────────────────────────────────────────────────── */
  :global(html.darkmode) .ap-panel {
    background: linear-gradient(180deg, var(--dm-surface-2) 0%, var(--dm-surface-1) 100%);
    border-color: var(--dm-border-sub);
  }

  :global(html.darkmode) .ap-panel__content {
    color: var(--dm-fg-muted);
    border-top-color: var(--dm-border);
  }

  :global(html.darkmode) .ap-list li {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-list li + li {
    border-top-color: var(--dm-border-sub);
  }

  :global(html.darkmode) .ap-aim-text {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-section__subtitle {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-goal {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-meta-item {
    color: var(--dm-fg);
  }

  :global(html.darkmode) .ap-module-row:not(:last-child)::after {
    border-left-color: color-mix(in oklab, var(--brand-AP) 40%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-module {
    background: linear-gradient(155deg, var(--dm-surface-2) 0%, var(--dm-surface-1) 55%);
    border-color: var(--dm-border-sub);
  }

  :global(html.darkmode) .ap-module__header h3 a {
    color: var(--dm-fg);
  }

  :global(html.darkmode) .ap-module__header h3 a:hover,
  :global(html.darkmode) .ap-module__header h3 a:focus-visible {
    color: var(--brand-AP);
  }

  :global(html.darkmode) .ap-module__toggle {
    background: color-mix(in oklab, var(--brand-AP) 18%, var(--dm-surface-3));
    border-color: color-mix(in oklab, var(--brand-AP) 35%, var(--dm-border));
    color: var(--brand-AP);
  }

  :global(html.darkmode) .ap-module__header:hover .ap-module__toggle {
    background: var(--brand-AP);
    border-color: var(--brand-AP);
    color: #1c1917;
  }

  :global(html.darkmode) .ap-divider {
    color: color-mix(in oklab, var(--brand-AP), white 20%);
  }

  :global(html.darkmode) .ap-divider::before,
  :global(html.darkmode) .ap-divider::after {
    border-top-color: color-mix(in oklab, var(--brand-AP) 50%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-divider--center {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-item-download {
    background: var(--dm-surface-1);
    color: color-mix(in oklab, var(--brand-AP), white 25%);
    border-color: color-mix(in oklab, var(--brand-AP) 40%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-item-download:hover {
    background: var(--brand-AP);
    color: #1c1917;
    border-color: var(--brand-AP);
  }

  :global(html.darkmode) .ap-module-card {
    background: color-mix(in oklab, var(--module-card-color, var(--brand-AP)) 12%, var(--dm-surface-1));
    border-color: color-mix(in oklab, var(--module-card-color, var(--brand-AP)) 40%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-module-card h4 {
    color: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), white 35%);
  }

  :global(html.darkmode) .ap-card-text {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-card-button {
    background: var(--module-card-color, var(--brand-AP));
    border-color: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), black 10%);
    color: #ffffff;
  }

  :global(html.darkmode) .ap-card-button:hover {
    background: color-mix(in oklab, var(--module-card-color, var(--brand-AP)), white 15%);
    border-color: var(--module-card-color, var(--brand-AP));
    color: #ffffff;
  }

  :global(html.darkmode) .ap-teaching-guide {
    background: color-mix(in oklab, var(--brand-AP) 14%, var(--dm-surface-2));
    border-color: color-mix(in oklab, var(--brand-AP) 35%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-package-banner {
    background: color-mix(in oklab, var(--brand-AP) 14%, var(--dm-surface-2));
    border-color: color-mix(in oklab, var(--brand-AP) 35%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-package-banner__title {
    color: var(--dm-fg);
  }

  :global(html.darkmode) .ap-package-banner__sub {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-tabs__bar {
    border-bottom-color: color-mix(in oklab, var(--brand-AP) 30%, var(--dm-border-sub));
  }

  :global(html.darkmode) .ap-tab {
    color: var(--dm-fg-muted);
  }

  :global(html.darkmode) .ap-tab:hover {
    color: color-mix(in oklab, var(--brand-AP), white 20%);
  }

  :global(html.darkmode) .ap-tab[aria-selected="true"] {
    color: var(--dm-fg);
  }

  :global(html.darkmode) .ap-tab__badge {
    background: color-mix(in oklab, var(--brand-AP) 25%, var(--dm-surface-3));
    color: color-mix(in oklab, var(--brand-AP), white 30%);
  }

  :global(html.darkmode) .ap-tab[aria-selected="true"] .ap-tab__badge {
    background: var(--brand-AP);
    color: #1c1917;
  }

