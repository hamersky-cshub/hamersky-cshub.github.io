---
import '../../styles/tailwind.css'
import '../../assets/scss/index.scss'
import LocalizedPageRoute from '@components/LocalizedPageRoute.astro'
import { getLocalizedPageStaticPaths } from '../../i18n/localizedPages'

export const getStaticPaths = () => [
  { params: { slug: undefined } },
  ...getLocalizedPageStaticPaths(),
]

const { slug } = Astro.params
const route = slug ?? ''
---

<LocalizedPageRoute route={route} />
