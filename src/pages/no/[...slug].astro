---
import LocalizedPageRoute from '@components/LocalizedPageRoute.astro'
import { getLocalizedPageStaticPaths } from 'src/i18n/localizedPages'

export const getStaticPaths = () => [
  { params: { slug: undefined } },
  ...getLocalizedPageStaticPaths(),
]

const { slug } = Astro.params
const route = slug ?? ''
---

<LocalizedPageRoute route={route} />
